### Frontend (Vite / React) ###
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.env
frontend/.env.*
!frontend/.env.example
frontend/*.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.vite/

### Backend (Python / FastAPI — lives at repo root) ###
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/

# Uploaded / generated files — don't commit user data or captured frames
uploads/*
!uploads/.gitkeep

# Model weights & caches (InsightFace / MediaPipe — large, re-downloadable)
**/.insightface/
*.onnx
models/*.task
!models/challenge.py

# Training artifacts (train.py / antispoof) — usually large and regenerable
antispoof/saved_logs/
antispoof/datasets/
antispoof/resources/*.pth
antispoof/resources/*.onnx

### Environment & secrets ###
.env
.env.local
.env.*.local
*.pem
*.key

### OS / editor cruft ###
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

### Logs ###
*.log