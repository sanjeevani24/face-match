# Directory where database (ekyc.db) and uploads/ folder will be stored
DATA_DIR=/var/www/html/face-match/data

# Directory where InsightFace models will be downloaded and stored
INSIGHTFACE_HOME=/var/www/html/face-match/data/.insightface

# Comma-separated list of origins allowed to make requests to the API (use HTTPS)
ALLOWED_ORIGINS=https://face-match.auremoai.site
